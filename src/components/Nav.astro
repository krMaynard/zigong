---
import LanguageSwitcher from './LanguageSwitcher.astro';
import ThemeToggle from './ThemeToggle.astro';
import { useTranslations, localizedUrl } from '../i18n/utils';
import { routes, type Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
  currentPath: string;
}
const { locale, currentPath } = Astro.props;
const t = useTranslations(locale);

const links = [
  { slug: routes.heritage, label: t('nav.heritage') },
  { slug: routes.culture, label: t('nav.culture') },
  { slug: routes.industry, label: t('nav.industry') },
  { slug: routes.everyday, label: t('nav.everyday') },
  { slug: routes.people, label: t('nav.people') },
  { slug: routes.about, label: t('nav.about') },
].map((l) => ({ ...l, href: localizedUrl(locale, l.slug) }));

const homeHref = localizedUrl(locale, routes.home);
const isActive = (href: string) =>
  href === homeHref ? currentPath === href : currentPath.startsWith(href);
---

<header class="site-header">
  <div class="container nav-inner">
    <a class="brand" href={homeHref}>
      <span class="brand-name">{t('site.name')}</span><span class="brand-tld">.fyi</span>
    </a>

    <nav class="primary-nav" aria-label={t('nav.menu')}>
      <button class="nav-toggle" aria-expanded="false" aria-controls="nav-links" aria-label={t('nav.menu')}>
        <span class="nav-toggle-bar" aria-hidden="true"></span>
      </button>
      <ul class="nav-links" id="nav-links">
        {links.map((l) => (
          <li>
            <a href={l.href} aria-current={isActive(l.href) ? 'page' : undefined}>{l.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="nav-tools">
      <LanguageSwitcher locale={locale} currentPath={currentPath} />
      <ThemeToggle label={t('theme.toggle')} />
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--bg) 90%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    min-height: 3.75rem;
  }
  .brand {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 1.3rem;
    color: var(--text-strong);
    text-decoration: none;
    white-space: nowrap;
    letter-spacing: 0.01em;
  }
  .brand-tld { color: var(--accent); }

  .primary-nav { margin-left: auto; display: flex; align-items: center; }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.2rem;
    list-style: none;
    padding: 0;
    margin: 0;
    flex-wrap: wrap;
  }
  .nav-links a {
    display: inline-block;
    padding: 0.4rem 0.6rem;
    border-radius: var(--radius);
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.92rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.15s ease, background 0.15s ease;
  }
  .nav-links a:hover { color: var(--accent-deep); background: var(--accent-soft); }
  .nav-links a[aria-current='page'] { color: var(--accent-deep); }

  .nav-tools { display: flex; align-items: center; gap: 0.5rem; }

  .nav-toggle { display: none; background: none; border: none; padding: 0; }

  @media (max-width: 880px) {
    .nav-toggle {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 2.5rem;
      height: 2.5rem;
      border: 1px solid var(--border-strong);
      border-radius: var(--radius);
      cursor: pointer;
      background: var(--bg-elevated);
    }
    .nav-toggle-bar,
    .nav-toggle-bar::before,
    .nav-toggle-bar::after {
      content: '';
      display: block;
      width: 1.2rem;
      height: 2px;
      background: var(--text);
      border-radius: 2px;
      position: relative;
    }
    .nav-toggle-bar::before { position: absolute; top: -6px; }
    .nav-toggle-bar::after { position: absolute; top: 6px; }

    .nav-links { display: none; }
    .nav-links.open {
      display: flex;
      position: absolute;
      right: var(--gutter);
      left: var(--gutter);
      top: 3.75rem;
      flex-direction: column;
      align-items: stretch;
      background: var(--bg-elevated);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow-lg);
      padding: 0.5rem;
      gap: 0.05rem;
    }
    .nav-links.open a { display: block; }
  }
</style>

<script is:inline>
  (function () {
    var toggle = document.querySelector('.nav-toggle');
    var links = document.getElementById('nav-links');
    if (!toggle || !links) return;
    function setOpen(open) {
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      links.classList.toggle('open', open);
    }
    toggle.addEventListener('click', function () {
      setOpen(toggle.getAttribute('aria-expanded') !== 'true');
    });
    links.addEventListener('click', function (e) {
      if (e.target.closest('a')) setOpen(false);
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') setOpen(false);
    });
  })();
</script>
