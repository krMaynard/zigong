---
interface Props {
  href: string;
  emoji: string;
  title: string;
  blurb: string;
  cta: string;
  accent?: 'lantern' | 'salt' | 'dinosaurs' | 'kids' | 'tech' | 'businesses';
}
const { href, emoji, title, blurb, cta, accent = 'lantern' } = Astro.props;
---

<a class="card pillar-card" href={href} data-accent={accent}>
  <span class="card-emoji" aria-hidden="true">{emoji}</span>
  <h3>{title}</h3>
  <p>{blurb}</p>
  <span class="card-go">{cta} →</span>
</a>

<style>
  /* Each card carries its own accent so the top bar + hover color match the pillar. */
  .pillar-card[data-accent='salt'] { --accent: var(--jade); --accent-deep: color-mix(in srgb, var(--jade) 78%, black); --accent-soft: color-mix(in srgb, var(--jade) 14%, transparent); }
  .pillar-card[data-accent='dinosaurs'] { --accent: var(--ink-blue); --accent-deep: color-mix(in srgb, var(--ink-blue) 78%, black); --accent-soft: color-mix(in srgb, var(--ink-blue) 14%, transparent); }
  .pillar-card[data-accent='kids'] { --accent: var(--plum); --accent-deep: color-mix(in srgb, var(--plum) 78%, black); --accent-soft: color-mix(in srgb, var(--plum) 14%, transparent); }
  .pillar-card[data-accent='tech'] { --accent: var(--jade); --accent-deep: color-mix(in srgb, var(--jade) 78%, black); --accent-soft: color-mix(in srgb, var(--jade) 14%, transparent); }
  .pillar-card[data-accent='businesses'] { --accent: var(--gold); --accent-deep: color-mix(in srgb, var(--gold) 52%, black); --accent-soft: color-mix(in srgb, var(--gold) 18%, transparent); }
</style>
