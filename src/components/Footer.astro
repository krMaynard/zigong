---
import { useTranslations, localizedUrl } from '../i18n/utils';
import { routes, type Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const year = new Date().getFullYear();

const footerLinks = [
  { slug: routes.heritage, label: t('nav.heritage') },
  { slug: routes.culture, label: t('nav.culture') },
  { slug: routes.industry, label: t('nav.industry') },
  { slug: routes.everyday, label: t('nav.everyday') },
  { slug: routes.people, label: t('nav.people') },
  { slug: routes.about, label: t('nav.about') },
].map((l) => ({ ...l, href: localizedUrl(locale, l.slug) }));
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <p class="footer-name">{t('site.name')}<span class="footer-tld">.fyi</span></p>
        <p class="footer-tagline">{t('site.tagline')}</p>
      </div>
      <nav class="footer-nav" aria-label={t('nav.menu')}>
        {footerLinks.map((l) => <a href={l.href}>{l.label}</a>)}
      </nav>
    </div>

    <p class="disclaimer" role="note">{t('footer.disclaimer')}</p>

    <p class="footer-meta">
      <span>© {year} zigong.fyi</span>
      <span aria-hidden="true">·</span>
      <span>{t('footer.builtBy')}</span>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: auto;
    background: var(--bg-subtle);
    border-top: 1px solid var(--border);
    padding-block: clamp(2.5rem, 6vw, 4rem);
  }
  .footer-top {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem 2.5rem;
    justify-content: space-between;
    align-items: flex-start;
  }
  .footer-name { font-family: var(--font-serif); font-weight: 700; font-size: 1.2rem; color: var(--text-strong); margin: 0; }
  .footer-tld { color: var(--accent); }
  .footer-tagline { color: var(--text-muted); font-size: 0.92rem; margin: 0.3rem 0 0; max-width: 38ch; }

  .footer-nav { display: flex; flex-wrap: wrap; gap: 0.4rem 1.1rem; }
  .footer-nav a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.9rem;
    font-family: var(--font-sans);
    font-weight: 500;
  }
  .footer-nav a:hover { color: var(--accent-deep); }

  .disclaimer {
    margin-top: 1.8rem;
    padding-top: 1.2rem;
    border-top: 1px solid var(--border);
    color: var(--text-faint);
    font-size: 0.84rem;
    max-width: none;
    font-family: var(--font-sans);
  }
  .footer-meta {
    margin-top: 1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    color: var(--text-faint);
    font-size: 0.84rem;
    max-width: none;
    font-family: var(--font-sans);
  }
</style>
