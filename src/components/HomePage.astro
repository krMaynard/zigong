---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from './Hero.astro';
import { asLocale, useTranslations, localizedUrl } from '../i18n/utils';
import { routes } from '../i18n/ui';
import { home, type ThemeKey } from '../i18n/home';

const locale = asLocale(Astro.currentLocale);
const t = useTranslations(locale);
const content = home[locale];

const slugByKey: Record<ThemeKey, string> = {
  heritage: routes.heritage,
  culture: routes.culture,
  industry: routes.industry,
  everyday: routes.everyday,
  people: routes.people,
};
---

<BaseLayout>
  <Hero title={t('site.name')} tagline={content.lead} />

  <section class="section">
    <div class="container">
      <div class="prose overview">
        {content.overview.map((p) => <p>{p}</p>)}
      </div>

      <p class="eyebrow themes-label">{content.themesLabel}</p>
      <div class="grid grid-themes">
        {content.themes.map((theme) => (
          <a class="card" href={localizedUrl(locale, slugByKey[theme.key])}>
            <h3>{theme.title}</h3>
            <p>{theme.blurb}</p>
            <span class="card-go">{theme.title} →</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .overview { font-size: 1.12rem; }
  .themes-label { margin: clamp(2.5rem, 6vw, 4rem) 0 1.2rem; }
</style>
