---
// Renders a responsive gallery of placeholder photo frames. Each item is a
// labelled SVG placeholder until real photography is dropped in by filename.
interface Item {
  caption: string;
  /** Optional real image src; falls back to a generated placeholder. */
  src?: string;
  emoji?: string;
}
interface Props {
  items: Item[];
  note?: string;
}
const { items, note } = Astro.props;

const placeholder = (emoji = '📷') =>
  `data:image/svg+xml;utf8,` +
  encodeURIComponent(
    `<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 400 300'>` +
      `<rect width='400' height='300' fill='%23fdeedd'/>` +
      `<text x='50%' y='50%' font-size='84' text-anchor='middle' dominant-baseline='central'>${emoji}</text>` +
      `</svg>`,
  );
---

<div class="photo-strip">
  {items.map((item) => (
    <figure class="photo-frame">
      <img src={item.src ?? placeholder(item.emoji)} alt={item.caption} loading="lazy" />
      <figcaption>{item.caption}</figcaption>
    </figure>
  ))}
</div>
{note && <p class="photo-note">{note}</p>}

<style>
  .photo-note { margin-top: 0.8rem; font-size: 0.85rem; color: var(--text-faint); text-align: center; max-width: none; }
</style>
