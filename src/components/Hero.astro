---
interface Props {
  eyebrow?: string;
  title: string;
  tagline?: string;
}
const { eyebrow, title, tagline } = Astro.props;
---

<header class="hero">
  <div class="container container-narrow hero-inner">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1 class="hero-title">{title}</h1>
    {tagline && <p class="hero-tagline">{tagline}</p>}
    <div class="hero-actions"><slot /></div>
  </div>
</header>

<style>
  .hero {
    padding-block: clamp(2.5rem, 7vw, 4.5rem) clamp(1.5rem, 4vw, 2.5rem);
    border-bottom: 1px solid var(--border);
  }
  .hero-inner { margin-inline: 0; }
  .hero .eyebrow { margin-bottom: 0.9rem; }
  .hero-title { max-width: 16ch; }
  .hero-tagline {
    font-size: clamp(1.1rem, 2.2vw, 1.4rem);
    color: var(--text-muted);
    margin-top: 0.9rem;
    max-width: 34em;
  }
  .hero-actions:not(:empty) { display: flex; flex-wrap: wrap; gap: 0.7rem; margin-top: 1.4rem; }
</style>
