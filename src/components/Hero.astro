---
interface Props {
  eyebrow?: string;
  title: string;
  tagline?: string;
  accent?: string;
}
const { eyebrow, title, tagline } = Astro.props;
---

<section class="hero">
  <div class="hero-lanterns lanterns-row" aria-hidden="true">
    <span class="lantern"><span class="bulb"></span></span>
    <span class="lantern"><span class="bulb"></span></span>
    <span class="lantern"><span class="bulb"></span></span>
    <span class="lantern"><span class="bulb"></span></span>
    <span class="lantern"><span class="bulb"></span></span>
  </div>
  <div class="container hero-inner">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1 class="hero-title">{title}</h1>
    {tagline && <p class="hero-tagline">{tagline}</p>}
    <div class="hero-actions"><slot /></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-block: clamp(2.5rem, 7vw, 5rem);
    text-align: center;
    overflow: hidden;
    background:
      radial-gradient(ellipse at 50% -20%, color-mix(in srgb, var(--accent) 22%, transparent), transparent 60%);
  }
  .hero-lanterns { margin-bottom: 1.5rem; }
  .hero-inner { display: flex; flex-direction: column; align-items: center; gap: 0.6rem; }
  .hero-title {
    max-width: 18ch;
    background: linear-gradient(120deg, var(--accent-deep), var(--gold-deep));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .hero-tagline { font-size: clamp(1.05rem, 2.4vw, 1.35rem); color: var(--text-muted); max-width: 44ch; }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 0.8rem; justify-content: center; margin-top: 1.2rem; }
</style>
