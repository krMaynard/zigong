---
import ContentPage from '../components/ContentPage.astro';
import SectionPage from '../components/SectionPage.astro';
import { sectionPaths, type SectionPathProps } from '../lib/content';

export async function getStaticPaths() {
  return sectionPaths('zh');
}

const props = Astro.props as SectionPathProps;
---

{props.kind === 'section'
  ? <SectionPage sectionKey={props.sectionKey} entries={props.entries} />
  : <ContentPage entry={props.entry} />}
