---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
---

<BaseLayout title="页面未找到">
  <Hero
    eyebrow="404"
    title="这里没有页面"
    tagline="你要找的页面也许已经移动，或者从未存在。"
  >
    <a class="btn btn-primary" id="home-link" href="/">返回首页</a>
  </Hero>
</BaseLayout>

<script is:inline>
  // Chinese is the default at the root; localize for the /en/, /ja/, /ko/ prefixes.
  (function () {
    var seg = window.location.pathname.split('/')[1];
    var L = {
      en: { lang: 'en', doc: 'Page not found · Zigong', title: 'Nothing here', tagline: 'The page you’re looking for may have moved, or never existed.', home: 'Back to the overview' },
      ja: { lang: 'ja', doc: 'ページが見つかりません · 自貢', title: 'ここにはページがありません', tagline: 'お探しのページは移動したか、もともと存在しないようです。', home: 'トップへ戻る' },
      ko: { lang: 'ko', doc: '페이지를 찾을 수 없습니다 · 쯔궁', title: '여기에는 페이지가 없습니다', tagline: '찾으시는 페이지가 이동했거나 처음부터 없는 것 같습니다.', home: '처음으로' },
    };
    var t = L[seg];
    if (!t) return;
    document.documentElement.setAttribute('lang', t.lang);
    document.title = t.doc;
    var set = function (sel, text) { var el = document.querySelector(sel); if (el) el.textContent = text; };
    set('.hero-title', t.title);
    set('.hero-tagline', t.tagline);
    var home = document.getElementById('home-link');
    if (home) { home.setAttribute('href', '/' + seg + '/'); home.textContent = t.home; }
  })();
</script>
